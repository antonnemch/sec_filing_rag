# Copy this file to .env and replace every value you need. Never commit .env.

# SEC EDGAR requires automated clients to identify a responsible person.
SEC_IDENTITY="Your Name your.email@example.com"

# OpenAI provides embeddings for FAISS retrieval and semantic scoring.
OPENAI_API_KEY="sk-..."

# Anthropic Claude generates RAG answers and optionally acts as an LLM judge.
ANTHROPIC_API_KEY="sk-ant-..."

# Optional retrieval depth. An explicit run_eval --k value overrides this.
RAG_TOP_K=5
